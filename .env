# Copia este archivo a .env y ajusta los valores para producción.
# En desarrollo local los defaults del docker-compose ya funcionan.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# IMPORTANTE: en producción usa una clave de al menos 256 bits (32+ caracteres)
JWT_SECRET=cambiar-esta-clave-secreta-de-al-menos-256-bits-en-produccion
